# ============================================================
# .htaccess - Portal Informasi Kelurahan Pulomerak
# Keamanan & Konfigurasi Apache
# ============================================================

Options -Indexes
ServerSignature Off

# ── Charset & bahasa default ─────────────────────────────────
AddDefaultCharset UTF-8

# ── Blokir akses ke file sensitif ────────────────────────────
<FilesMatch "\.(sql|log|env|ini|sh|htpasswd)$">
    Order Deny,Allow
    Deny from all
</FilesMatch>

# Blokir akses ke folder include
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteRule ^include/.*$ - [F,L]
</IfModule>

# ── PHP Security Headers ──────────────────────────────────────
<IfModule mod_headers.c>
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set X-XSS-Protection "1; mode=block"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>

# ── Gzip Compression ─────────────────────────────────────────
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/css text/javascript application/javascript text/plain
</IfModule>

# ── Browser Cache ─────────────────────────────────────────────
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType image/jpeg   "access plus 1 month"
    ExpiresByType image/png    "access plus 1 month"
    ExpiresByType image/webp   "access plus 1 month"
    ExpiresByType image/gif    "access plus 1 month"
    ExpiresByType text/css     "access plus 1 week"
    ExpiresByType text/javascript "access plus 1 week"
    ExpiresByType application/javascript "access plus 1 week"
</IfModule>

# ── PHP Settings (jika hosting mendukung) ─────────────────────
<IfModule mod_php.c>
    php_value upload_max_filesize 10M
    php_value post_max_size 12M
    php_value max_execution_time 60
    php_value memory_limit 128M
</IfModule>

# ── Halaman Error Custom ──────────────────────────────────────
ErrorDocument 404 /PuloMerak/pulomerak/404.php
ErrorDocument 403 /PuloMerak/pulomerak/404.php
